      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def generate_melody(length = 8, scale = scale.MajorScale('C')):\n",
        "  melody = stream.Stream()\n",
        "\n",
        "  for _ in range (length):\n",
        "    pitch = random.choice(scale.getPitches(\"C4\", \"C5\"))\n",
        "\n",
        "    # Quarter, Half, Dotted Half, Whole Node\n",
        "\n",
        "    duration = random.choice([0.5, 1, 1.5, 2])\n",
        "    new_note = note.Note(pitch)\n",
        "    new_note.duration.quarterLength = duration\n",
        "    melody.append(new_note)\n",
        "\n",
        "  return melody"
      ],
      "metadata": {
        "id": "GGFZEfoMzrMV"
      },
      "execution_count": 10,
      "outputs": []
    },

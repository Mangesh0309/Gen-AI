      "source": [
        "# Combining Poetry and Music"
      ],
      "metadata": {
        "id": "yGxNkSlQ3Nug"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def poem_to_melody(poem, scale = scale.MajorScale(\"A\")):\n",
        "\n",
        "  words = poem.split()\n",
        "\n",
        "  melody = stream.Stream()\n",
        "\n",
        "  for word in words [:16]:    #Limit to 8 notes for simplicity\n",
        "    pitch = scale.pitchFromDegree((len(word)%15) + 1)\n",
        "    duration = len(word) * 0.25     # Quarter node for each letter\n",
        "    new_note = note.Note(pitch)\n",
        "    new_note.duration.quarterLength = duration\n",
        "    melody.append(new_note)\n",
        "  return melody"
      ],
      "metadata": {
        "id": "DqqX797x3RPr"
      },
      "execution_count": 13,
      "outputs": []
